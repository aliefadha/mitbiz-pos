# ==========================================
# Database Configuration
# ==========================================
# For Cloud Run: Use your Google Compute Engine PostgreSQL instance IP
# Format: postgresql://USER:PASSWORD@GCE_EXTERNAL_IP:5432/DB_NAME
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=pos_user
DB_PASSWORD=pos_password
DB_NAME=pos_database
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5435/pos_database

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# ==========================================
# API Configuration
# ==========================================
# IMPORTANT: Cloud Run injects PORT automatically (usually 8080)
# The app reads process.env.PORT, so this works automatically in Cloud Run
# Only set PORT manually for local development
PORT=3000
API_PREFIX=/api

# ==========================================
# Better Auth Configuration
# ==========================================
# BETTER_AUTH_URL must match your Cloud Run service URL in production
# Example: https://backend-pos-xyz-uc.a.run.app
BETTER_AUTH_SECRET=your-super-secret-auth-key-min-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ==========================================
# Admin Credentials
# ==========================================
# These are used for initial admin user creation
ADMIN_EMAIL=superadmin@mitbiz.com
ADMIN_PASSWORD=your-secure-admin-password

# ==========================================
# CORS Configuration
# ==========================================
# For Cloud Run: Set this to your frontend URL(s)
# Example: https://your-frontend-app.com or multiple origins separated by commas
ALLOWED_ORIGINS=http://localhost:3000,https://pos.mitbiz.id,*
FRONTEND_URL=http://localhost:3000

# ==========================================
# Email / SMTP Configuration
# ==========================================
# Development (MailHog - for local use only):
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mitbiz.com

# Production (Gmail or other SMTP):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@mitbiz.com

# ==========================================
# Midtrans Payment Configuration
# ==========================================
# Get your keys from https://dashboard.midtrans.com
# Sandbox keys start with SB-Mid-
# Production keys start with Mid-
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false
# FRONTEND_URL is already defined above in CORS Configuration

# ==========================================
# Google Cloud Run Deployment Guide
# ==========================================
# Required Environment Variables for Cloud Run:
#
# 1. DATABASE_URL: Your PostgreSQL connection string pointing to GCE instance
#    Example: postgresql://pos_user:pos_password@34.120.XX.XX:5432/pos_database
#
# 2. BETTER_AUTH_SECRET: Minimum 32 characters, generate with: openssl rand -base64 32
#
# 3. BETTER_AUTH_URL: Your Cloud Run service URL
#    Example: https://backend-pos-xyz-uc.a.run.app
#
# 4. JWT_SECRET: Generate a strong secret: openssl rand -base64 32
#
# 5. ALLOWED_ORIGINS: Your frontend URL(s) for CORS
#    Example: https://your-frontend.com
#
# 6. SMTP_* variables: Configure for production email delivery
#
# Set these when deploying:
# gcloud run deploy backend-pos \
#   --set-env-vars "DATABASE_URL=postgresql://..." \
#   --set-env-vars "BETTER_AUTH_SECRET=..." \
#   --set-env-vars "BETTER_AUTH_URL=https://..." \
#   --set-env-vars "JWT_SECRET=..." \
#   --set-env-vars "ALLOWED_ORIGINS=https://..."