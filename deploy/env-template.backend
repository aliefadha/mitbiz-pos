# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://pos_user:pos_password@DB_HOST:5432/pos_database

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ==========================================
# API Configuration
# ==========================================
PORT=3001
API_PREFIX=/api

# ==========================================
# Better Auth Configuration
# ==========================================
BETTER_AUTH_SECRET=your-super-secret-auth-key-min-32-characters
BETTER_AUTH_URL=https://api-pos.mitbiz.id

# ==========================================
# CORS Configuration
# ==========================================
ALLOWED_ORIGINS=https://pos.mitbiz.id,https://api-pos.mitbiz.id
FRONTEND_URL=https://pos.mitbiz.id

# ==========================================
# Midtrans Payment Configuration
# ==========================================
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_FINISH_URL=https://pos.mitbiz.id/payment/success
MIDTRANS_NOTIFICATION_URL=https://pos.mitbiz.id/api/payment/notification
